rules_version = '2';
// Firebase Storage rules – blog images and other uploads
// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    // Blog featured images: blog/{postId}/featured.*
    // Anyone can read (public blog). Only signed-in users can write (admin posts from dashboard).
    match /blog/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Optional: restrict other paths or add more rules below
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
